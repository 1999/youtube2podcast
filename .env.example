R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
YOUTUBE_API_KEY=your_youtube_api_key
# Optional: path to a Netscape-format cookies.txt file for yt-dlp (helps avoid bot detection)
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
# Optional: Netscape-format cookie content inline (alternative to YTDLP_COOKIES_FILE)
# YTDLP_COOKIES="# Netscape HTTP Cookie File\n.youtube.com TRUE / TRUE 0 COOKIE_NAME value"
